# ==========================================
# 1. 依赖包 (Dependencies)
# ==========================================
node_modules/
/.pnp
.pnp.js

# ==========================================
# 2. Next.js 临时构建输出与缓存 (Build & Cache)
# ==========================================
.next/
out/
build/
dist/
.docusaurus/

# ==========================================
# 3. 环境变量与敏感配置 (Environment Variables)
# - 必须严格禁止上传，避免泄露 API Key (如 Groq, Gemini 等)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ==========================================
# 4. 调试与日志文件 (Logs)
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 5. 测试覆盖率报告 (Testing)
# ==========================================
coverage/
.nyc_output/

# ==========================================
# 6. 操作系统临时文件 (System Files)
# ==========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ==========================================
# 7. 编辑器/IDE 专属配置文件 (Editor Configurations)
# ==========================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?